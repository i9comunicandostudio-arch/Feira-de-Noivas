{
  "entities": {
    "User": {
      "title": "User",
      "description": "Exhibitor user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["exhibitor", "admin"] }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile document"
    }
  }
}
